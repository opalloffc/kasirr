<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardTransaksi"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    style="?attr/materialCardViewElevatedStyle"
    android:foreground="?android:attr/selectableItemBackground">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/iv_status_rekap"
            android:layout_width="140dp"
            android:layout_height="80dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="-10dp"
            android:layout_marginEnd="-20dp"
            android:alpha="0.3"
            android:rotation="-20"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_hutang" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KONSUMEN"
                android:textSize="9sp"
                android:letterSpacing="0.1"
                android:alpha="0.6"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_nama_rekap"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Amar"
                android:textColor="?attr/colorOnSurface"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="DAFTAR BELANJA"
                android:textSize="9sp"
                android:alpha="0.5"
                android:fontFamily="sans-serif-medium" />

            <LinearLayout
                android:id="@+id/container_produk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="?android:attr/listDivider"
                android:alpha="0.2" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Total Kewajiban"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_total_harga_rekap"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="Rp 0"
                    android:textColor="#F44336"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_item_pdf"
                    style="?attr/materialIconButtonFilledTonalStyle"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:icon="@drawable/ic_pdf"
                    app:iconTint="?attr/colorPrimary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_item_share"
                    style="?attr/materialIconButtonFilledTonalStyle"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginHorizontal="8dp"
                    app:icon="@drawable/ic_whatsapp"
                    app:iconTint="#4CAF50" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_lunasi"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lunasi"
                    android:textStyle="bold"
                    android:backgroundTint="#4CAF50"
                    android:textColor="@android:color/white"
                    app:iconGravity="textStart"
                    app:icon="@drawable/ic_check"
                    app:iconTint="@android:color/white" />
                    
                   <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_struk"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_marginStart="6dp"
                    android:layout_height="wrap_content"
                    android:text="Cetak"
                    android:textStyle="bold"
                    android:layout_weight="1"
                    app:iconGravity="textStart"
                    app:icon="@drawable/ic_print"
                    app:iconTint="?attr/colorPrimary" />
                    
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_date_badge"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="6dp"
                    android:alpha="0.7"
                    android:src="@drawable/ic_clock"
                    app:tint="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tv_tanggal_update_rekap"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Diupdate: Hari ini, 12:45"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="9sp" />
            </LinearLayout>

        </LinearLayout>
        
    </FrameLayout>
    
</com.google.android.material.card.MaterialCardView>
