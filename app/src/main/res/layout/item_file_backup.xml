<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_height="wrap_content"
     android:layout_width="match_parent"
     android:layout_marginVertical="6dp"
     android:clickable="true"
     app:cardElevation="0dp"
     style="?attr/materialCardViewFilledStyle"
     app:cardCornerRadius="16dp"
     android:focusable="true"
     android:id="@+id/cardItem"
     android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:gravity="center_vertical"
         android:padding="16dp"
         android:orientation="horizontal">

        <ImageView
             android:layout_height="48dp"
             android:layout_width="48dp"
             android:padding="8dp"
             app:srcCompat="@drawable/ic_restore"
             android:id="@+id/ivFileIcon" />

        <LinearLayout
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:orientation="vertical"
             android:layout_marginStart="16dp">

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:ellipsize="middle"
                 android:textStyle="bold"
                 android:maxLines="1"
                 android:id="@+id/tvFileName"
                 android:text="A3Mart_Senin.bak" />

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:gravity="center_vertical"
                 android:orientation="horizontal"
                 android:layout_marginTop="2dp"
                 android:id="@+id/layoutMeta">

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="wrap_content"
                     android:alpha="0.6"
                     android:textSize="12sp"
                     android:textColor="?attr/colorOnSurfaceVariant"
                     android:id="@+id/tvFileInfo"
                     android:text="11 Feb 2026" />

                <View
                     android:layout_height="4dp"
                     android:layout_width="4dp"
                     android:background="@drawable/dot_separator"
                     android:alpha="0.3"
                     android:layout_marginHorizontal="8dp" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="wrap_content"
                     android:alpha="0.6"
                     android:textSize="12sp"
                     android:id="@+id/tvTimeInfo"
                     android:text="13:45" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>